import serial
import time

PORT = "/dev/tty.usbmodem1101"  # change this
BAUD = 9600

ser = serial.Serial(PORT, BAUD, timeout=1)
time.sleep(2)  # Arduino reset delay

print("Connected. Reading temperature...\n")

while True:
    line = ser.readline().decode("utf-8").strip()

    if not line:
        continue

    if line.startswith("ERR"):
        print(f"Arduino error: {line}")
        continue

    try:
        temp_c = float(line)
        temp_f = temp_c * 9/5 + 32
        print(f"{temp_c:.2f} °C | {temp_f:.2f} °F")
    except ValueError:
        print(f"Unknown message: {line}")